# SMTP configuration options for the email service
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com

# Meta WhatsApp Cloud API (official — sends PDF without QR scan)
# Create app: https://developers.facebook.com/ → WhatsApp → API Setup
# WHATSAPP_PROVIDER=auto
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_API_VERSION=v21.0
# WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=

# Meta Embedded Signup (multi-tenant — each org connects own WABA)
# META_APP_ID=
# META_APP_SECRET=
# META_EMBEDDED_SIGNUP_CONFIG_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-string
# WHATSAPP_WEBHOOK_SECRET=          # defaults to META_APP_SECRET
# BACKEND_PUBLIC_URL=https://your-api.onrender.com
# FRONTEND_URL=https://your-app.vercel.app
# Pre-App-Review fallback: static Meta-hosted Embedded Signup link (GET /v1/whatsapp-cloud/meta-link)
# META_HOSTED_LINK=

# WhatsApp business-assistant AI replies use the existing GEMINI_API_KEY / GEMINI_CHAT_MODEL above.